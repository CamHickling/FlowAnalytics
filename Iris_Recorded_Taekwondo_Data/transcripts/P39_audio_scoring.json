    {
      "start": 346.14000000000004,
      "end": 347.64000000000004,
      "text": "And for presentation,"
    },
    {
      "start": 347.64000000000004,
      "end": 352.84000000000003,
      "text": "we had 1.7, 1, 2, 3."
